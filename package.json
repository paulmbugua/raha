{
  "name": "mindcare-online-therapy",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@4.9.1+sha512.f95ce356460e05be48d66401c1ae64ef84d163dd689964962c6888a9810865e39097a5e9de748876c2e0bf89b232d583c33982773e9903ae7a76257270986538",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "nohoist": [
    "**/react-native",
    "**/react-native/**",
    "**/expo",
    "**/expo/**",
    "**/@expo/metro-config",
    "**/@expo/metro-config/**"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build:all": "yarn workspaces run build",
    "start": "yarn workspace @mindcare/backend start",
    "start:backend": "yarn workspace @mindcare/backend start",
    "start:web": "yarn workspace @mindcare/web start",
    "dev:admin": "yarn workspace @mindcare/admin dev",
    "build:admin": "yarn workspace @mindcare/admin build",
    "start:admin": "serve -s apps/admin/dist",
    "build": "turbo run build --filter=@mindcare/backend... --filter=@mindcare/web... --filter=@mindcare/admin...",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "test": "turbo run test",
    "playwright:install:backend": "yarn workspace @mindcare/backend playwright:install",
    "railway:build:backend": "yarn install --immutable",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "install:natives": "node scripts/check-native-modules.js",
    "reset:expo": "node reset-health.js",
    "health:android": "node android-health.js"
  },
  "devDependencies": {
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@expo/cli": "^54.0.6",
    "@expo/metro-config": "^54.0.3",
    "@opennextjs/cloudflare": "^1.18.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@types/lodash.debounce": "^4.0.9",
    "@types/react-native-vector-icons": "6.4.18",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^8",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^4.3.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.5",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "metro": "^0.83.1",
    "metro-cache": "^0.83.1",
    "metro-config": "^0.83.1",
    "metro-resolver": "^0.83.1",
    "postcss": "^8.4.21",
    "prettier": "^3.5.3",
    "rimraf": "3.0.2",
    "serve": "^14.2.4",
    "tailwindcss": "^3.3.2",
    "turbo": "^2.4.4",
    "wrangler": "^4.78.0"
  },
  "dependencies": {
    "@google-cloud/speech": "^7.2.1",
    "firebase-admin": "^13.5.0"
  },
  "resolutions": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "19.0.3",
    "@expo/metro-config": "54.0.3",
    "firebase": "12.2.1",
    "@tanstack/react-query": "5.89.0",
    "@tanstack/react-query-devtools": "5.89.0",
    "@tanstack/query-core": "5.89.0",
    "expo-constants": "18.0.10",
    "expo-web-browser": "15.0.8",
    "axios": "1.12.2"
  }
}
