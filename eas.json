{
  "cli": { "version": ">= 3.0.0", "appVersionSource": "remote" },
  "build": {
    "development": {
      "workingDirectory": "apps/mobile",
      "node": "20.19.4",
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "android": { "buildType": "apk", "image": "latest" }
    },
    "preview": {
      "extends": "development",
      "environment": "preview",
      "android": { "buildType": "app-bundle" }
    },
    "production": {
      "workingDirectory": "apps/mobile",
      "node": "20.19.4",
      "autoIncrement": true,
      "environment": "production",
      "android": { "buildType": "app-bundle", "image": "latest" }
    }
  },
  "submit": { "production": {} }
}
