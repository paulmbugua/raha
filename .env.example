# MindCare backend
PORT=4005
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional generic M-Pesa callback fallback.
# Daraja callback URLs must be publicly reachable in production.
MPESA_CALLBACK_URL=https://your-public-domain/api/mpesa/callback

# Secret Nairobi email confirmation sender.
SMTP_HOST=smtp.your-provider.example
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@secretnairobi.co.ke
SMTP_PASS=
MAIL_FROM_NAME=Secret Nairobi
MAIL_FROM_ADDRESS=noreply@secretnairobi.co.ke
MAIL_FROM="Secret Nairobi <noreply@secretnairobi.co.ke>"
MAIL_REPLY_TO=noreply@secretnairobi.co.ke

# Cloudflare R2 media buckets and public custom domains.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_IMAGES=secretnairobi-images
R2_PUBLIC_BASE_URL_IMAGES=https://images.secretnairobi.co.ke
R2_BUCKET_PREVIEWS=secretnairobi-previews
R2_PUBLIC_BASE_URL_PREVIEWS=https://previews.secretnairobi.co.ke
R2_BUCKET_DOCS=
R2_PUBLIC_BASE_URL_DOCS=
