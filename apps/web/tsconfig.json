{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "preserve",
    "types": ["react", "react-dom", "node", "next"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared": ["../../packages/shared"],
      "@shared/*": ["../../packages/shared/*"],
      "@mindcare/shared": [
        "../../packages/shared/index.ts",
        "../../packages/shared/index.d.ts"
      ],
      "@mindcare/shared/*": ["../../packages/shared/*"],
      "@mindcare/shared/types": [
        "../../packages/shared/types/index.ts",
        "../../packages/shared/types/index.d.ts"
      ]
    },
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "*.ts",
    "*.tsx",
    "../../packages/shared/**/*.ts",
    "../../packages/shared/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "build"
  ]
}