    "three": "^0.179.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/canvas-confetti": "^1",
    "@types/lodash.debounce": "^4",
    "@types/qrcode": "^1",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "@types/react-native-web": "^0",
    "@types/three": "^0",
    "eslint": "^9.23.0",
    "eslint-config-next": "^16.2.1",
    "prettier": "^3.5.3",
    "typescript": "^5.6.3",
    "wrangler": "^4.78.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
