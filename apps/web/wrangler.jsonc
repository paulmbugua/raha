{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "Utamu",
  "compatibility_date": "2026-03-27",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "Utamu"
    }
  ],
  "vars": {
    "NEXT_PUBLIC_BACKEND_URL": "https://api.utamu.co.ke"
  },
  "routes": [
    {
      "pattern": "utamu.co.ke",
      "custom_domain": true
    },
    {
      "pattern": "www.utamu.co.ke",
      "custom_domain": true
    }
  ]
}
