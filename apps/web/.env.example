# Utamu web environment template
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:4005

# Google OAuth client ID, not a secret but project-specific.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_WEB=replace-with-google-oauth-client-id.apps.googleusercontent.com

# Firebase public web config. Restrict API key usage in Google Cloud Console.
NEXT_PUBLIC_FIREBASE_API_KEY=replace-with-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace-with-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace-with-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace-with-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=replace-with-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=replace-with-measurement-id

NEXT_PUBLIC_PAYPAL_CLIENT_ID=replace-with-paypal-client-id
