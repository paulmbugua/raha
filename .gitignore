# --------------------------------
# Global ignores
# --------------------------------

# Node.js dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Build artifacts
build/
.cxx/

# Native Android/iOS folders (generated by expo prebuild)
apps/mobile/android/
apps/mobile/ios/

# NDK/Gradle build cache
**/build/
**/.cxx/

# Temporary Metro files
.metro-health-check*
.expo-shared/

# TypeScript build info
*.tsbuildinfo

# Certificates and sensitive files
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# Firebase Admin credentials (DO NOT COMMIT)
serviceAccount.json
**/serviceAccount.json
firebase-adminsdk-*.json
**/firebase-adminsdk-*.json

# macOS system files
.DS_Store

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local environment files
.env
.env.*
!.env.example
!**/.env.example
.env.*.local
.env.local

# Temporary examples or scratch files
app-example/

# IDE settings (optional but good)
.vscode/
.idea/

# Yarn integrity file (optional)
.yarn-integrity

# TurboRepo cache (if using Turbo)
turbo/

# Expo CLI server cache
.expo/

# Git LFS cache (optional, if using LFS)
*.lfsconfig

# Next.js build output
apps/web/.next/


# Next cache/logs
apps/web/.next/cache/


# Next.js build output
apps/web/.next/


